# Per-repo settings for the agentic loop kit. install.sh writes a copy of this into your
# target repo's loop/loop.config.sh with your answers filled in — this file is just the
# reference/example, and is safe to hand-edit after install too. loop/run.sh,
# loop/verify.sh, and loop/new_task.sh each source loop.config.sh if it exists and fall
# back to a generic default for anything unset, so a missing or partial config never
# breaks the loop — it just runs with weaker guardrails until you tighten it.

# Commands verify.sh runs after every maker attempt, from the repo root. Get these right
# early — an empty gate makes every task's "acceptance criteria met" claim unverifiable.
LOOP_KIT_BUILD_CMD="make build"
LOOP_KIT_TEST_CMD="make test"

# Extended-regex of path prefixes whose diffs always route to loop/queue/blocked/ for a
# human, regardless of what verify or the checker say — governance-sensitive changes
# don't get to self-approve. Add your own ADRs / provider-interface specs / schema-of-
# record files alongside the generic defaults below.
LOOP_KIT_SENSITIVE_PATTERN='^(deploy/|secrets|\.github/workflows/)'

# Working-principles doc the task/review prompt templates point makers and reviewers at
# (TDD requirement, architectural constraints, etc.). AGENTS.md is a common convention;
# change this if your project uses a different name/location.
LOOP_KIT_PRINCIPLES_DOC="AGENTS.md"

# Path to a roadmap/milestone doc, relative to the repo root. If set and the file exists,
# new_task.sh requires every task's `milestone:` field to match a `## <id> — ...` heading
# in it. Set to an empty string to disable milestone validation entirely (some projects
# don't track milestones as a doc).
LOOP_KIT_ROADMAP_DOC="docs/roadmap.md"

# --- harnesses: which CLIs are in the maker/checker rotation --------------------------------
#
# Space-separated, order matters: each harness is reviewed by the next one in this list,
# wrapping around (a ring) — see run.sh's reviewer_for(). Needs at least 2; a single harness
# can never review its own work. Every name here must have a matching
# loop/harnesses/<name>.sh adapter (loop/harnesses/TEMPLATE.sh.example documents the
# interface; `loop/new_harness.sh <name>` scaffolds a new one). This kit ships built-in
# adapters for codex, claude, and cursor — drop any subset of the three (still need >=2), or
# add your own (aider, gemini-cli, ...) alongside them.
LOOP_KIT_HARNESSES="codex claude cursor"

# Each built-in adapter reads its own model config below; unset ones fall back to the
# adapter's own defaults (see loop/harnesses/<name>.sh). MAKER_MODEL_DEFAULT/EFFORT_DEFAULT
# apply to a task with no `complexity:` frontmatter; _QUICK/_GNARLY are the cheaper/stronger
# tiers a task opts into with `complexity: quick`/`complexity: gnarly`. CHECKER_MODEL is used
# when this harness is reviewing someone else's diff (not tiered by complexity — review
# strength doesn't scale with a task's declared complexity).

# codex — reasoning effort is a separate config override, not baked into the model slug.
# LOOP_KIT_CODEX_MAKER_MODEL_DEFAULT="gpt-5.6-terra"
# LOOP_KIT_CODEX_MAKER_EFFORT_DEFAULT="high"
# LOOP_KIT_CODEX_MAKER_MODEL_QUICK="gpt-5.6-luna"
# LOOP_KIT_CODEX_MAKER_EFFORT_QUICK="high"
# LOOP_KIT_CODEX_MAKER_MODEL_GNARLY="gpt-5.6-sol"
# LOOP_KIT_CODEX_MAKER_EFFORT_GNARLY="high"
# LOOP_KIT_CODEX_CHECKER_MODEL="gpt-5.6-terra"

# claude — --effort is a separate CLI flag from --model, same shape as codex's above.
# LOOP_KIT_CLAUDE_MAKER_MODEL_DEFAULT="sonnet"
# LOOP_KIT_CLAUDE_MAKER_EFFORT_DEFAULT="high"
# LOOP_KIT_CLAUDE_MAKER_MODEL_QUICK="sonnet"
# LOOP_KIT_CLAUDE_MAKER_EFFORT_QUICK="medium"
# LOOP_KIT_CLAUDE_MAKER_MODEL_GNARLY="opus"
# LOOP_KIT_CLAUDE_MAKER_EFFORT_GNARLY="high"
# LOOP_KIT_CLAUDE_CHECKER_MODEL="sonnet"

# cursor — its model slug already bakes in reasoning effort (e.g. grok-4.5-high), so one flat
# model covers every complexity tier and both the maker and checker roles.
# LOOP_KIT_CURSOR_MODEL="grok-4.5-high"
# LOOP_KIT_CURSOR_MAKER_TIMEOUT="900"

# A custom harness (anything you scaffolded with loop/new_harness.sh) reads whatever
# LOOP_KIT_<NAME>_* vars its own loop/harnesses/<name>.sh adapter defines — see that file.
