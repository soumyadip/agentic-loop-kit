# Per-repo settings for the agentic loop kit. install.sh writes a copy of this into your
# target repo's loop/loop.config.sh with your answers filled in — this file is just the
# reference/example, and is safe to hand-edit after install too. loop/run.sh,
# loop/verify.sh, and loop/new_task.sh each source loop.config.sh if it exists and fall
# back to a generic default for anything unset, so a missing or partial config never
# breaks the loop — it just runs with weaker guardrails until you tighten it.

# Commands verify.sh runs after every maker attempt, from the repo root. Get these right
# early — an empty gate makes every task's "acceptance criteria met" claim unverifiable.
LOOP_KIT_BUILD_CMD="make build"
LOOP_KIT_TEST_CMD="make test"

# Extended regex of path prefixes that always require a human before merge. Matching diffs
# skip the checker entirely and go to loop/queue/blocked/ — two models agreeing cannot
# auto-merge these. (Older name LOOP_KIT_SENSITIVE_PATTERN is still read as a fallback;
# install.sh --update renames it.)
LOOP_KIT_REQUIRE_HUMAN_REVIEW_PATHS='^(deploy/|secrets|\.github/workflows/)'

# Working-principles doc the task/review prompt templates point makers and reviewers at
# (TDD requirement, architectural constraints, etc.). AGENTS.md is a common convention;
# change this if your project uses a different name/location.
LOOP_KIT_PRINCIPLES_DOC="AGENTS.md"

# Path to a roadmap/milestone doc, relative to the repo root. If set and the file exists,
# new_task.sh requires every task's `milestone:` field to match a `## <id> — ...` heading
# in it. Set to an empty string to disable milestone validation entirely (some projects
# don't track milestones as a doc).
LOOP_KIT_ROADMAP_DOC="docs/roadmap.md"

# --- harnesses: which maker/checker "seats" are in the rotation -----------------------------
#
# Space-separated *members*, order matters: each member is reviewed by the next one in this
# list, wrapping around (a ring) — see run.sh's reviewer_for(). Needs at least 2 members; a
# single member can never review its own work. A member is either a bare harness name
# ("cursor", using that harness's own configured default model below) or "harness:model"
# ("cursor:grok-4.5-high"), pinning a specific model — which lets one multi-model-capable
# harness like cursor, copilot, or opencode fill more than one seat by itself, e.g.:
#   LOOP_KIT_HARNESSES="cursor:grok-4.5-high cursor:claude-4.5-sonnet"
#   LOOP_KIT_HARNESSES="copilot:gpt-5.4 copilot:claude-sonnet-4.6"
#   LOOP_KIT_HARNESSES="opencode:nvidia/z-ai/glm-5.2 opencode:opencode/big-pickle"
# is a valid 2-member rotation using only one CLI — a diff made under one model family is
# still meaningfully checked by a different one, even sharing one adapter/account.
# Every member's harness portion must have a matching loop/harnesses/<name>.sh adapter
# (loop/harnesses/TEMPLATE.sh.example documents the interface; `loop/new_harness.sh <name>`
# scaffolds a new one). This kit ships built-in adapters for codex, claude, cursor, copilot,
# and opencode — drop any subset (still need >=2 members total), reorder them, repeat one with
# different pinned models, or add your own alongside them.
LOOP_KIT_HARNESSES="codex claude cursor"

# Each built-in adapter reads its own model config below; unset ones fall back to the
# adapter's own defaults (see loop/harnesses/<name>.sh). These only apply to *bare* members
# (no ':model' of their own) — a pinned member like "cursor:grok-4.5-high" always uses exactly
# that model and ignores LOOP_KIT_CURSOR_MODEL entirely. MAKER_MODEL_DEFAULT/EFFORT_DEFAULT
# apply to a task with no `complexity:` frontmatter; _QUICK/_GNARLY are the cheaper/stronger
# tiers a task opts into with `complexity: quick`/`complexity: gnarly` (also skipped for a
# pinned member — an explicit model choice isn't re-tiered). CHECKER_MODEL is used when this
# harness is reviewing someone else's diff (not tiered by complexity — review strength doesn't
# scale with a task's declared complexity).

# codex — reasoning effort is a separate config override, not baked into the model slug.
# LOOP_KIT_CODEX_MAKER_MODEL_DEFAULT="gpt-5.6-terra"
# LOOP_KIT_CODEX_MAKER_EFFORT_DEFAULT="high"
# LOOP_KIT_CODEX_MAKER_MODEL_QUICK="gpt-5.6-luna"
# LOOP_KIT_CODEX_MAKER_EFFORT_QUICK="high"
# LOOP_KIT_CODEX_MAKER_MODEL_GNARLY="gpt-5.6-sol"
# LOOP_KIT_CODEX_MAKER_EFFORT_GNARLY="high"
# LOOP_KIT_CODEX_CHECKER_MODEL="gpt-5.6-terra"

# claude — --effort is a separate CLI flag from --model, same shape as codex's above.
# LOOP_KIT_CLAUDE_MAKER_MODEL_DEFAULT="sonnet"
# LOOP_KIT_CLAUDE_MAKER_EFFORT_DEFAULT="high"
# LOOP_KIT_CLAUDE_MAKER_MODEL_QUICK="sonnet"
# LOOP_KIT_CLAUDE_MAKER_EFFORT_QUICK="medium"
# LOOP_KIT_CLAUDE_MAKER_MODEL_GNARLY="opus"
# LOOP_KIT_CLAUDE_MAKER_EFFORT_GNARLY="high"
# LOOP_KIT_CLAUDE_CHECKER_MODEL="sonnet"

# cursor — its model slug already bakes in reasoning effort (e.g. grok-4.5-high), so one flat
# model covers every complexity tier and both the maker and checker roles.
# LOOP_KIT_CURSOR_MODEL="grok-4.5-high"
# LOOP_KIT_CURSOR_MAKER_TIMEOUT="900"

# copilot — GitHub Copilot CLI (`copilot`). Multi-model (GPT / Claude / Gemini ids — see
# `copilot /model` for your plan). Optional --effort when the model supports it.
# LOOP_KIT_COPILOT_MODEL="gpt-5.4"
# LOOP_KIT_COPILOT_EFFORT=""
# LOOP_KIT_COPILOT_EFFORT_QUICK=""
# LOOP_KIT_COPILOT_EFFORT_GNARLY="high"
# LOOP_KIT_COPILOT_MAKER_TIMEOUT="900"

# opencode — provider/model slugs (`opencode models`). Maker uses --agent build; reviewer/
# council use --agent plan. Optional --variant for reasoning effort.
# LOOP_KIT_OPENCODE_MODEL="nvidia/z-ai/glm-5.2"
# LOOP_KIT_OPENCODE_VARIANT=""
# LOOP_KIT_OPENCODE_VARIANT_QUICK=""
# LOOP_KIT_OPENCODE_VARIANT_GNARLY="high"
# LOOP_KIT_OPENCODE_MAKER_TIMEOUT="900"

# A custom harness (anything you scaffolded with loop/new_harness.sh) reads whatever
# LOOP_KIT_<NAME>_* vars its own loop/harnesses/<name>.sh adapter defines — see that file.

# --- council: who gets asked independent design/scope questions -----------------------------
#
# Space-separated *members*, same "harness" or "harness:model" syntax as LOOP_KIT_HARNESSES
# above — see council.sh's own header comment. Unlike the maker/checker ring, council doesn't
# need >=2 distinct members (there's no self-review adjacency concern for independent opinions
# gathered in parallel with no cross-visibility), just diminishing value in asking the same
# member twice. Each member's harness portion needs a loop/harnesses/<name>.sh adapter
# implementing harness_council_run — codex, claude, cursor, copilot, and opencode all do out of
# the box.
LOOP_KIT_COUNCIL_HARNESSES="codex opencode claude"

# Shared across every council member's adapter (not per-harness — a council run is meant to
# finish in one sitting, so there's no reason to tier this by CLI).
# LOOP_KIT_COUNCIL_TIMEOUT="900"

# Each adapter's council seat has its own model default, independent of that harness's
# maker/checker models above — only applies to a *bare* member (no ':model' of its own).
# LOOP_KIT_CODEX_COUNCIL_MODEL=""               # empty = let the codex CLI's own default decide
# LOOP_KIT_CLAUDE_COUNCIL_MODEL="sonnet"
# LOOP_KIT_CURSOR_COUNCIL_MODEL="grok-4.5-high" # falls back to LOOP_KIT_CURSOR_MODEL if unset
# LOOP_KIT_COPILOT_COUNCIL_MODEL="gpt-5.4"      # falls back to LOOP_KIT_COPILOT_MODEL if unset
# LOOP_KIT_OPENCODE_COUNCIL_MODEL="nvidia/z-ai/glm-5.2"  # falls back to LOOP_KIT_OPENCODE_MODEL

# Skip specific members for a single run without editing this file (space-separated, matching
# entries in LOOP_KIT_COUNCIL_HARNESSES exactly) — set as an env var when invoking council.sh,
# not here, e.g.: COUNCIL_SKIP="opencode" loop/council.sh question.md

# --- SkillOpt-Sleep: refine the project loop skill from loop/log evidence -------------------
#
# Optional offline companion (Microsoft SkillOpt). Exports maker/checker transcripts into a
# SkillOpt-Sleep tasks file, replays them under the current project skill, and stages bounded
# edits to the LEARNED block only when a held-out gate improves. Requires `pip install skillopt`
# (or `uv tool install skillopt`). See loop/README.md "SkillOpt-Sleep".
#
# Backends (subscription-first — no Anthropic/OpenAI API key required for these):
#   mock     — plumbing only
#   claude   — logged-in Claude Code CLI (`claude -p`)
#   codex    — logged-in Codex CLI (`codex exec`)
#   handoff  — Sleep writes prompts; loop/skillopt_handoff.sh answers via harness_council_run
#              (claude / codex / cursor / copilot / opencode). Needs SkillOpt newer than
#              PyPI 0.2.0 for handoff.
#
# Engine defaults that aren't CLI flags (evolve_memory=false, gate_mode=on, …) live in
# ~/.skillopt-sleep/config.json — start from loop/skillopt-sleep.config.json.example.
LOOP_KIT_SKILLOPT_SKILL_PATH=".claude/skills/project-loop/SKILL.md"
LOOP_KIT_SKILLOPT_BACKEND="mock"          # mock | claude | codex | handoff
LOOP_KIT_SKILLOPT_HANDOFF_HARNESS=""      # empty = first LOOP_KIT_HARNESSES member (e.g. claude)
LOOP_KIT_SKILLOPT_TASKS_FILE=""           # empty = loop/state/skillopt-tasks.json
LOOP_KIT_SKILLOPT_MAX_TASKS="40"
LOOP_KIT_SKILLOPT_EDIT_BUDGET="4"
# LOOP_KIT_SKILLOPT_PREFERENCES="Prefer pytest. Keep commits imperative and scoped."

# Activity triggers from loop/run.sh (see loop/skillopt_trigger.sh). Thresholds are *since
# last successful trigger* (loop/state/skillopt-trigger.json), not absolute done/ size.
#   off      — never nudge / auto-run from the loop
#   remind   — print how to run SkillOpt when the threshold is hit (default; no model)
#   dry-run  — auto export + dry-run (never adopts)
#   run      — auto export + run (stages only; never auto-adopts)
LOOP_KIT_SKILLOPT_TRIGGER="remind"
LOOP_KIT_SKILLOPT_TRIGGER_EVERY_DONE="10"   # 0 = disable count-based firing
LOOP_KIT_SKILLOPT_TRIGGER_ON_RUN_END="1"    # 1 = evaluate at end of run.sh; 0 = after each done/
LOOP_KIT_SKILLOPT_TRIGGER_BACKEND="mock"    # mock | claude | codex | handoff for auto dry-run/run
